{
  "name": "cron",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-21",

  "triggers": {
    "crons": [
      "0 8 * * *", // once a day, 12/1AM PST - all init api calls
      "0 8 * * 1", // once a week, 12/1AM PST - process withdraws
      "*/30 * * * *", // every 30 minutes - database backup
    ],
  },
}
