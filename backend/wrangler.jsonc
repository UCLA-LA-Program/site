{
  "name": "cron",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-21",

  "triggers": {
    "crons": [
      "0 8 * * *",     // once a day, 12/1AM PST
      "0 8 * * 1"      // once a week, 12/1AM PST
    ]
  },

  "vars": {
    "APP_URL": "NEED TO FIX LATER" // Production app URL
  }

  // CRON_SECRET should be set via: wrangler secret put CRON_SECRET
}
