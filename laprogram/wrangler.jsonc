{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "laprogram",
  "compatibility_date": "2026-03-15",
  "compatibility_flags": ["nodejs_compat"],
  "preview_urls": true,
  "env": {
    "staging": {
      "workers_dev": true,
    },
  },
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS",
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "laprogram",
    },
  ],
  "images": {
    "binding": "IMAGES",
  },
  "observability": {
    "enabled": true,
  },
}
